<Window x:Class="Laba1.Windows.Compiler"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Laba1.Windows"
        mc:Ignorable="d"
        Title="Компилятор"
        Height="650"
        Width="900"
        MinHeight="500"
        MinWidth="700"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Image">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Создать" Click="Create_Click"/>
                <MenuItem Header="Открыть" Click="Open_Click"/>
                <MenuItem Header="Сохранить" Click="Save_Click"/>
                <MenuItem Header="Сохранить как" Click="SaveAs_Click"/>
                <Separator/>
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="Правка">
                <MenuItem Header="Отменить" Command="Undo"/>
                <MenuItem Header="Повторить" Command="Redo"/>
                <Separator/>
                <MenuItem Header="Вырезать" Command="Cut"/>
                <MenuItem Header="Копировать" Command="Copy"/>
                <MenuItem Header="Вставить" Command="Paste"/>
                <MenuItem Header="Удалить" Command="EditingCommands.Delete"/>
                <Separator/>
                <MenuItem Header="Выделить все" Command="SelectAll"/>
            </MenuItem>

            <MenuItem Header="Текст">
                <MenuItem Header="Постановка задачи"/>
                <MenuItem Header="Грамматика"/>
                <MenuItem Header="Классификация грамматики"/>
                <MenuItem Header="Метод анализа"/>
                <MenuItem Header="Тестовый пример"/>
                <MenuItem Header="Список литературы"/>
                <MenuItem Header="Исходный код программы"/>
            </MenuItem>

            <MenuItem Header="Пуск">
                <MenuItem Header="Выполнить анализ" Click="RunAnalysis_Click"/>
                <MenuItem Header="Показать AST" Click="ShowAst_Click"/>
            </MenuItem>

            <MenuItem Header="Справка">
                <MenuItem Header="Вызов справки" Click="Reference_Click"/>
                <Separator/>
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button ToolTip="Создать" Click="Create_Click">
                    <Image Source="/Images/create.png"/>
                </Button>
                <Button ToolTip="Открыть" Click="Open_Click">
                    <Image Source="/Images/folder.png"/>
                </Button>
                <Button ToolTip="Сохранить" Click="Save_Click">
                    <Image Source="/Images/save.png"/>
                </Button>
                <Separator/>
                <Button ToolTip="Назад" Command="Undo">
                    <Image Source="/Images/left-arrow.png"/>
                </Button>
                <Button ToolTip="Вперед" Command="Redo">
                    <Image Source="/Images/right-arrow.png"/>
                </Button>
                <Separator/>
                <Button ToolTip="Копировать" Command="Copy">
                    <Image Source="/Images/copy.png"/>
                </Button>
                <Button ToolTip="Вырезать" Command="Cut">
                    <Image Source="/Images/cut.png"/>
                </Button>
                <Button ToolTip="Вставить" Command="Paste">
                    <Image Source="/Images/insert.png"/>
                </Button>
                <Separator/>
                <Button ToolTip="Пуск" Click="RunAnalysis_Click">
                    <Image Source="/Images/play.png"/>
                </Button>
                <Button ToolTip="Показать AST" Click="ShowAst_Click">
                    <TextBlock Text="AST" FontWeight="Bold" Foreground="DeepPink"/>
                </Button>
                <Button ToolTip="Вызов справки" Click="Reference_Click">
                    <Image Source="/Images/question.png"/>
                </Button>
                <Button ToolTip="О программе" Click="About_Click">
                    <Image Source="/Images/exclamation.png"/>
                </Button>
            </ToolBar>
        </ToolBarTray>

        <Grid DockPanel.Dock="Bottom" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.1*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1.5*"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Файл" Margin="0,0,0,2">
                <RichTextBox x:Name="FileContentViewer"
                             TextChanged="FileContentViewer_TextChanged"
                             Background="White"
                             BorderBrush="Gray"
                             BorderThickness="1"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Padding="5"
                             FontFamily="Consolas"
                             FontSize="12">
                    <FlowDocument LineHeight="16"
                                  LineStackingStrategy="BlockLineHeight"
                                  PagePadding="0">
                        <Paragraph Margin="0" Padding="1">
                            <Run Text="Dictionary&lt;int, string&gt; My_dict1 = new Dictionary&lt;int, string&gt; {&#10;    { 1, &quot;one&quot; },&#10;    { 2, &quot;two&quot; },&#10;    { 3, &quot;three&quot; }&#10;};&#10;"/>
                        </Paragraph>
                    </FlowDocument>
                </RichTextBox>
            </GroupBox>

            <GridSplitter Grid.Row="1"
                          Height="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="Silver"
                          ShowsPreview="True"
                          ResizeBehavior="PreviousAndNext"/>

            <GroupBox Grid.Row="2" Header="Вывод" Margin="0,2,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1.6*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="5,0,5,5">
                        <TextBlock Text="Лексический разбор"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="LexicalCountText"
                                   Margin="20,0,0,0"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              x:Name="TokensDataGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              Background="White"
                              BorderBrush="Gray"
                              BorderThickness="1"
                              RowHeaderWidth="0"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="NavajoWhite"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding Number}" Width="50"/>
                            <DataGridTextColumn Header="Лексема" Binding="{Binding Lexeme}" Width="160"/>
                            <DataGridTextColumn Header="Тип токена" Binding="{Binding TokenType}" Width="150"/>
                            <DataGridTextColumn Header="Объяснение" Binding="{Binding Description}" Width="220"/>
                            <DataGridTextColumn Header="Строка" Binding="{Binding Line}" Width="70"/>
                            <DataGridTextColumn Header="Позиция" Binding="{Binding Column}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="2"
                                  Height="5"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Center"
                                  Background="Silver"
                                  ShowsPreview="True"
                                  ResizeBehavior="PreviousAndNext"/>

                    <DockPanel Grid.Row="3" Margin="5,5,5,5">
                        <TextBlock Text="Синтаксический разбор"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="SyntaxCountText"
                                   Margin="20,0,0,0"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="TotalCountText"
                                   Margin="20,0,0,0"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                    </DockPanel>

                    <DataGrid Grid.Row="4"
                              x:Name="SyntaxErrorsDataGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              Background="White"
                              BorderBrush="Gray"
                              BorderThickness="1"
                              RowHeaderWidth="0"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="MistyRose"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              SelectionChanged="SyntaxErrorsDataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Неверный фрагмент" Binding="{Binding InvalidFragment}" Width="180"/>
                            <DataGridTextColumn Header="Местоположение" Binding="{Binding Location}" Width="150"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding Message}" Width="*"/>
                            <DataGridTextColumn Header="Строка" Binding="{Binding Line}" Width="70"/>
                            <DataGridTextColumn Header="Позиция" Binding="{Binding Column}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>