<Window x:Class="Laba1.Windows.SemanticErrorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Семантические ошибки"
        Height="400"
        Width="750"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <DataGrid x:Name="ErrorsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  RowHeaderWidth="0"
                  Background="White"
                  BorderBrush="Gray"
                  BorderThickness="1"
                  AlternatingRowBackground="MistyRose">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Сообщение" Binding="{Binding Message}" Width="*"/>
                <DataGridTextColumn Header="Строка" Binding="{Binding Line}" Width="80"/>
                <DataGridTextColumn Header="Позиция" Binding="{Binding Column}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>